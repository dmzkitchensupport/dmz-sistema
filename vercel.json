{
  "version": 2,
  "builds": [
    {
      "src": "api/rac-proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/convert-heic.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/rac-proxy/(.*)",
      "dest": "/api/rac-proxy.js"
    },
    {
      "src": "/api/convert-heic",
      "dest": "/api/convert-heic.py"
    },
    {
      "src": "/",
      "dest": "/AUDITORIA_AI_v9.html"
    },
    {
      "src": "/auditoria",
      "dest": "/AUDITORIA_AI_v9.html"
    },
    {
      "src": "/(.*)",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      },
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}